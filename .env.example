# Proxy server port
PORT=3000

# Optional: If set, clients must provide this key in the Authorization header
# PROXY_API_KEY=sk-proxy-secret

# XAI provider configuration
XAI_API_KEY=xai-your-key-here
XAI_BASE_URL=https://api.x.ai
XAI_DEFAULT_MODEL=grok-4.3

# Anthropic provider configuration
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514
ANTHROPIC_VERSION=2023-06-01

# Default max_tokens if not provided (Anthropic requires this)
DEFAULT_MAX_TOKENS=4096

# State manager TTL in milliseconds (default: 30 days)
STATE_MANAGER_TTL=2592000000
